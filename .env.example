# Backend API Configuration
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database (if not using SQLite)
DATABASE_URL=sqlite:///./restaurant.db

# ========================================
# AIRPAY PAYMENT INTEGRATION
# ========================================

# Airpay API Configuration
# Get these from your Airpay merchant dashboard
AIRPAY_API_URL=https://api.airpay.com/v1
AIRPAY_API_KEY=your_api_key_here
AIRPAY_MERCHANT_ID=your_merchant_id_here
AIRPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Webhook Configuration
# These URLs must be publicly accessible and point to your server
AIRPAY_CALLBACK_URL=https://yourdomain.com/api/payments/webhook
AIRPAY_RETURN_URL=https://yourdomain.com/payment/success

# Default Platform Fee (percentage)
# This will be applied to all payments by default
# Can be overridden per payment if needed
DEFAULT_PLATFORM_FEE_PERCENTAGE=10

# ========================================
# OPTIONAL: Authentication & Security
# ========================================

# If implementing JWT tokens in the future
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ========================================
# OPTIONAL: Monitoring & Logging
# ========================================

# Logging Level
LOG_LEVEL=INFO

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Unsplash API (Optional - for automated high-quality images)
UNSPLASH_ACCESS_KEY=your_access_key_here

# ========================================
# ENVIRONMENT
# ========================================

# Environment: development, staging, production
ENVIRONMENT=development

# ========================================
# NOTES
# ========================================
# 1. Never commit the actual values to git - use .env.local
# 2. In production, set environment variables through your hosting platform
# 3. For webhook testing locally, use ngrok: ngrok http 8000
# 4. Then use ngrok URL for AIRPAY_CALLBACK_URL
